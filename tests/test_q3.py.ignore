import ic
import unittest


class TestQ3(unittest.TestCase):

    def check(self, array, result, K=3):
        #self.assertEqual(ic.highest_product(array, K), result)
        self.assertEqual(ic.highest_product2(array, K), result[0])

    def test_gotcha(self):
        self.check([-10, -10, 1, 3, 2], (300, set([-10, -10, 3])))

    def test_example(self):
        self.check([1, 10, -5, 1, -100], (5000, set([10, -5, -100])))

    def test_negative_odd(self):
        self.check(
            [-1, -2, -3, -2, -6, -4], (4, set([-1, -2, -2])))
